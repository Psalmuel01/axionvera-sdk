{
  "name": "@axionvera/core",
  "version": "0.1.0",
  "description": "Core SDK for interacting with Axionvera smart contracts on Stellar (Soroban).",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npx tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node ../../node_modules/eslint/bin/eslint.js src/**/*.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "size-limit": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^1.3.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.6",
    "ts-jest": "^29.2.5",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
