{
  "name": "axionvera-sdk-monorepo",
  "version": "0.1.0",
  "description": "TypeScript SDK for interacting with Axionvera smart contracts on Stellar (Soroban).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axionvera/axionvera-sdk.git"
  },
  "homepage": "https://github.com/axionvera/axionvera-sdk",
  "bugs": {
    "url": "https://github.com/axionvera/axionvera-sdk/issues"
  },
  "keywords": [
    "stellar",
    "soroban",
    "web3",
    "sdk",
    "axionvera",
    "typescript"
  ],
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "jest",
    "docs": "typedoc",
    "start": "npm run build --workspaces",
    "size": "size-limit",
    "release:dry-run": "semantic-release --dry-run",
    "dev": "npm run build --workspaces -- --watch"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^23.0.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "size-limit": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^1.3.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.6",
    "ts-jest": "^29.2.5",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts"
    ],
    "clearMocks": true,
    "projects": [
      {
        "displayName": "Unit Tests",
        "preset": "ts-jest",
        "testMatch": [
          "<rootDir>/tests/*.test.ts",
          "!<rootDir>/tests/e2e/*.test.ts"
        ],
        "testEnvironment": "node"
      },
      {
        "displayName": "E2E Tests",
        "preset": "ts-jest",
        "testMatch": [
          "<rootDir>/tests/e2e/*.test.ts"
        ],
        "testEnvironment": "jsdom",
        "setupFilesAfterEnv": [
          "<rootDir>/tests/e2e/setup.ts"
        ]
      }
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
